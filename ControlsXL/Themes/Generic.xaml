<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">


    <!-- Merges the specified dictionaries containing custom control styles into Themes\Generic.xaml -->
    <ResourceDictionary.MergedDictionaries>
        
        <!-- MERGE THE RESOURCES FOLDER FILES -->
        <ResourceDictionary Source="pack://application:,,,/ControlsXL;Component/Resources/Colors.xaml"/>
        <ResourceDictionary Source="pack://application:,,,/ControlsXL;Component/Resources/Fonts.xaml"/>

        <!-- MERGE THE DEFAULT SKIN -->
        <ResourceDictionary Source="pack://application:,,,/ControlsXL;Component/Resources/Styles/Default.xaml"/>

        <!-- MERGE THE DEFAULT APPEARANCE -->
        <ResourceDictionary Source="pack://application:,,,/ControlsXL;Component/Resources/Appearances/Default.xaml"/>

        <!-- MERGE THE CUSTOM CONTROL STYLES -->
        <ResourceDictionary Source="pack://application:,,,/ControlsXL;Component/Themes/LinkButton.xaml"/>
        <ResourceDictionary Source="pack://application:,,,/ControlsXL;Component/Themes/MarkerButton.xaml"/>
        <ResourceDictionary Source="pack://application:,,,/ControlsXL;Component/Themes/VectorButton.xaml"/>
        <ResourceDictionary Source="pack://application:,,,/ControlsXL;Component/Themes/SideBar.xaml"/>
        <ResourceDictionary Source="pack://application:,,,/ControlsXL;Component/Themes/MultipleDocumentInterface.xaml"/>

    </ResourceDictionary.MergedDictionaries>

    
</ResourceDictionary>
