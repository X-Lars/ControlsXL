<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:xl="clr-namespace:ControlsXL"
                    xmlns:common="clr-namespace:ControlsXL.Common">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/ControlsXL;Component/Resources/Geometry.xaml"/>
        <ResourceDictionary Source="pack://application:,,,/ControlsXL;Component/Resources/Fonts.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <common:ThicknessConverter x:Key="ThicknessConverter"/>
    <common:AddaptiveThicknessConverter x:Key="AdaptiveThicknessConverter"/>

    <Style TargetType="{x:Type xl:MDIChild}">
        <Setter Property="Background" Value="Pink"/>
        <Setter Property="MinHeight" Value="50"/>
        <Setter Property="MinWidth" Value="50"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <!-- IMPORTANT -->
        <Setter Property="Canvas.Left" Value="{Binding RelativeSource={RelativeSource Self}, Path=Position.X}"/>
        <Setter Property="Canvas.Top" Value="{Binding RelativeSource={RelativeSource Self}, Path=Position.Y}"/>
        <!-- IMPORTANT -->

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type xl:MDIChild}">
                    <!-- Use (Path=.) to bind byRef and NOT byVal so the data context can be updated. -->
                    <Border Background="{TemplateBinding Background}" 
                            DataContext="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=.}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                                <Button Content="Child Caption"/>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal">
                                <Button Content="Child Status"/>
                            </StackPanel>
                            <ContentPresenter Content="{TemplateBinding ContentControl.Content}"/>
                            <xl:MDIDecorator x:Name="ChildDecorator"/>
                        </DockPanel>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ChildDecorator" Property="ShowDecorator" Value="True"/>
                        </Trigger>
                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type xl:MDIHost}">

        <Setter Property="Background" Value="LightBlue"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type xl:MDIHost}">
                    <Border Background="{TemplateBinding Background}">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                                <Button Content="Host Menu"/>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Status Bar"/>
                            </StackPanel>

                            <ScrollViewer CanContentScroll="True" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <xl:MDICanvas IsItemsHost="True">

                                </xl:MDICanvas>
                            </ScrollViewer>

                        </DockPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>

        </Setter>
    </Style>

    <Style TargetType="{x:Type xl:MDICanvas}">
        <Setter Property="Background" Value="LightGreen"/>
    </Style>

    <Style TargetType="{x:Type xl:MDIDecorator}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type xl:MDIDecorator}">
                    <Grid Opacity="0">
                        <xl:MDIResizeHandle Opacity="0"
                                   Height="3"
                                    Cursor="SizeNS"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Stretch" />

                        <xl:MDIResizeHandle Width="3"
                                    Cursor="SizeWE"
                                    VerticalAlignment="Stretch"
                                    HorizontalAlignment="Left" />

                        <xl:MDIResizeHandle Width="3"
                                       Cursor="SizeWE"
                                       VerticalAlignment="Stretch"
                                       HorizontalAlignment="Right" />
                        <xl:MDIResizeHandle Height="3"
                                       Cursor="SizeNS"
                                       VerticalAlignment="Bottom"
                                       HorizontalAlignment="Stretch" />

                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type xl:MDIResizeChrome}">
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type xl:MDIResizeChrome}">
                    <Grid>
                        <xl:MDIResizeHandle Height="3"
                                    Cursor="SizeNS"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Stretch" />

                        <xl:MDIResizeHandle Width="3"
                                    Cursor="SizeWE"
                                    VerticalAlignment="Stretch"
                                    HorizontalAlignment="Left" />

                        <xl:MDIResizeHandle Width="3"
                                       Cursor="SizeWE"
                                       VerticalAlignment="Stretch"
                                       HorizontalAlignment="Right" />
                        <xl:MDIResizeHandle Height="3"
                                       Cursor="SizeNS"
                                       VerticalAlignment="Bottom"
                                       HorizontalAlignment="Stretch" />

                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style TargetType="{x:Type xl:MDIMoveChrome}">
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type xl:MDIMoveChrome}">
                    <Grid Background="Transparent">
                        <xl:MDIMoveHandle Height="23" Cursor="SizeAll" VerticalAlignment="Top" HorizontalAlignment="Stretch"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>



