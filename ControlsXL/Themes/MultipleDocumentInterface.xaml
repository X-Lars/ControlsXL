    <Style TargetType="{x:Type xl:MDIChild}" x:Name="ChildStyle">

        <Setter Property="Background" Value="DeepPink"/>
        <Setter Property="BorderBrush" Value="{DynamicResource {ComponentResourceKey xl:Styles, BorderBrush}}"/>
        <Setter Property="BorderThickness" Value="{DynamicResource {ComponentResourceKey xl:Styles, BorderThickness}}"/>
        <Setter Property="MinWidth" Value="{x:Static xl:MDIChild.MDICHILD_MINIMIZED_WIDTH}"/>
        <Setter Property="MinHeight" Value="{x:Static xl:MDIChild.MDICHILD_MINIMIZED_HEIGHT}"/>
        --><!--<Setter Property="Width" Value="100"/>-->
        <!--<Setter Property="Height" Value="100"/>--><!--
        
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type xl:MDIChild}">

                    <Canvas>
                    --><!-- MDICHILD WINDOW RESIZE HANDLES LAYOUT --><!--
                    <ContentControl Template="{StaticResource DesignerItemTemplate}">
                        --><!-- MDICHILD WINDOW BORDER --><!--
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            MinWidth="{TemplateBinding MinWidth}">

                       

                            --><!-- MDICHILD WINDOW LAYOUT PANEL --><!--
                            <DockPanel LastChildFill="True">

                                --><!-- MDICHILD WINDOW HEADER--><!--
                                <Grid x:Name="MDIChildHeader" 
                                      DockPanel.Dock="Top">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    --><!-- MDICHILD WIDOW SYSTEM BUTTON --><!--
                                    <xl:VectorButton x:Name="SystemButton"
                                                     Grid.Column="0"
                                                     Height="{x:Static xl:MDIChild.MDICHILD_HEADER_HEIGHT}"
                                                     Scale="0.8"
                                                     StrokeThickness="0"
                                                     Vector="{StaticResource GeometryWindows}"/>

                                    --><!-- MDICHILD WINDOW HEADER CAPTION --><!--
                                    <TextBlock x:Name="WindowTitle"
                                               Grid.Column="1"
                                               HorizontalAlignment="Left"
                                               Text="{TemplateBinding Title}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>

                                    --><!-- MDICHILD WINDOW HEADER DRAG THUMB --><!--
                                    <Thumb x:Name="HeaderThumb" 
                                           Grid.Column="1"
                                           Height="{x:Static xl:MDIChild.MDICHILD_HEADER_HEIGHT}"
                                           Opacity="0.5"
                                           Tag="{x:Static common:ThumbNames.Header}"/>

                                    --><!-- MDICHILD WINDOW HEADER BUTTONS --><!--
                                    <StackPanel x:Name="WindowButtons"
                                                Grid.Column="2"
                                                Height="{x:Static xl:MDIChild.MDICHILD_HEADER_HEIGHT}"
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal">

                                        <xl:VectorButton x:Name="MinimizeButton"
                                                         Scale="0.8"
                                                         StrokeThickness="0"
                                                         Vector="{StaticResource GeometryMinimize}"/>

                                        <xl:VectorButton x:Name="RestoreButton"
                                                         Scale="0.8"
                                                         StrokeThickness="0"
                                                         Vector="{StaticResource GeometryRestore}"
                                                         Visibility="Collapsed"/>

                                        <xl:VectorButton x:Name="MaximizeButton"
                                                         Scale="0.8"
                                                         StrokeThickness="0"
                                                         Vector="{StaticResource GeometryMaximize}"/>

                                        <xl:VectorButton x:Name="CloseButton"
                                                         OverridesDefaultStyle="True"
                                                         Scale="0.8"
                                                         StrokeThickness="0"
                                                         Vector="{StaticResource GeometryCross}">

                                            <xl:VectorButton.Resources>
                                                <SolidColorBrush x:Key="{ComponentResourceKey xl:Styles, MouseOverBackgroundBrush}" Color="White"/>
                                                <SolidColorBrush x:Key="{ComponentResourceKey xl:Styles, MouseOverBorderBrush}" Color="White"/>
                                            </xl:VectorButton.Resources>

                                            <xl:VectorButton.Style>
                                                <Style TargetType="{x:Type xl:VectorButton}" BasedOn="{StaticResource {x:Type xl:VectorButton}}">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="Red"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </xl:VectorButton.Style>

                                        </xl:VectorButton>
                                    </StackPanel>
                                </Grid>

                                --><!-- MDICHILD WINDOW CONTENT --><!--
                                <ContentControl x:Name="Content"
                                                Content="{TemplateBinding Content}"/>

                            </DockPanel>
                            
                           

                    </Border>
                    --><!-- MDICHILD WINDOW RESIZE HANDLES -->
                    <!--<Thumb x:Name="ThumbLeft" Tag="{x:Static common:ThumbNames.ThumbLeft}" Background="Orange" Cursor="SizeWE" Margin="-5, 0, -5, 0" Width="5" VerticalAlignment="Stretch" HorizontalAlignment="Left"/>-->
                    <!--<Thumb x:Name="ThumbRight" Tag="{x:Static common:ThumbNames.ThumbRight}" Background="Orange" Cursor="SizeWE" Margin="0, 0, -5, 0" Width="5" VerticalAlignment="Stretch" HorizontalAlignment="Right"/>--><!--
                    </ContentControl>
                    </Canvas>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>-->

</ResourceDictionary>